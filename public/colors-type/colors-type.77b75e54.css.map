}
.font-subtitle {
  font-family: "Montserrat", sans-serif;
  font-weight: 700;
  font-size: 19px;
  line-height: 23px;
  color: #1f2041;
}
.font-title {
  font-family: "Montserrat", sans-serif;
  font-weight: 700;
  font-size: 24px;
  line-height: 29px;
  color: #1f2041;
}
.def-block {
  width: 320px;
}
.sm-block {
  width: 266px;
}
.xsm-block {
  width: 150px;
}
.down-arrow {
  content: "";
  display: inline-block;
  position: absolute;
  width: 8.35px;
  height: 8.35px;
  border-top: 2px solid rgba(31, 32, 65, 0.5);
  border-right: 2px solid rgba(31, 32, 65, 0.5);
  transform: rotate(135deg);
}
