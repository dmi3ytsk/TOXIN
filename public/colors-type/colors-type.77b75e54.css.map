.ezdropdown {
  align-items: center;
  border: 1px solid rgba(31, 32, 65, 0.25);
  border-radius: 4px;
  margin-top: 5px;
  margin-bottom: 10px;
  cursor: pointer;
  display: flex;
  height: 44px;
  justify-content: space-between;
  padding: 0 15px;
  position: relative;
}
.ezdropdown:hover {
  border-color: rgba(31, 32, 65, 0.5);
}
.ezdropdown-open {
  border-bottom-left-radius: 0px;
  border-bottom-right-radius: 0px;
  border-color: rgba(31, 32, 65, 0.5);
}
.ezdropdown__selection {
  line-height: 18px;
  flex: 1;
  position: relative;
}
.ezdropdown__selection:after {
  right: 0;
  top: 20%;
}
.ezdropdown__menu {
  background-color: #ffffff;
  border: 1px solid rgba(31, 32, 65, 0.5);
  border-bottom-left-radius: 4px;
  border-bottom-right-radius: 4px;
  box-sizing: border-box;
  box-shadow: 0px 10px 20px rgba(31, 32, 65, 0.05);
  cursor: default;
  display: none;
  left: 0;
  margin: -2px -1px -1px;
  position: absolute;
  right: 0;
  top: 44px;
  transition: all 0.2s ease-in-out;
  z-index: 99999;
}
.ezdropdown__menu-open {
  display: block;
}
.ezdropdown__row, .ezdropdown__buttons {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 44px;
  padding: 0px 7px 0px 15px;
}
.ezdropdown__rowAction {
  display: flex;
  width: 92px;
  justify-content: space-between;
  align-items: center;
}
.ezdropdown__button {
  cursor: pointer;
  border-radius: 4px;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  height: 32px;
  color: #bc9cff;
  font-size: 12px;
  line-height: 15px;
}
.ezdropdown__button:hover {
  background: #f0f0f0;
}

.counterBtn {
  background: #ffffff;
  align-items: center;
  border: 1px solid rgba(31, 32, 65, 0.25);
  border-radius: 50%;
  display: flex;
  height: 30px;
  width: 30px;
  transition: all 0.2s ease-in-out;
  padding-left: 10.5px;
  color: rgba(31, 32, 65, 0.5);
}
.counterBtn:hover {
  background: #f0f0f0;
}

.disable {
  opacity: 0.35;
  cursor: default;
}
.disable:hover {
  background: none;
}

.hide {
  opacity: 0;
  visibility: hidden;
}
