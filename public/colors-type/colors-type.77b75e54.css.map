  transform: rotate(135deg);
}

.toggle {
  margin-bottom: 10px;
  margin-right: 20px;
}

.toggle__box:checked,
.toggle__box:not(:checked) {
  position: absolute;
  left: -9999px;
}

.toggle__box:checked + .toggle__content,
.toggle__box:not(:checked) + .toggle__content {
  display: inline-block;
  position: relative;
  padding-left: 50px;
  line-height: 24px;
  color: rgba(31, 32, 65, 0.5);
  cursor: pointer;
}

.toggle__box:checked + .toggle__content:before,
.toggle__box:not(:checked) + .toggle__content:before {
  content: "";
  position: absolute;
  left: 0px;
  top: 0px;
  width: 40px;
  height: 20px;
  border: 1px solid #bc9cff;
  border-bottom-left-radius: 10px;
  border-top-left-radius: 10px;
  border-bottom-right-radius: 10px;
  border-top-right-radius: 10px;
  background-color: #ffffff;
}

.toggle__box:not(:checked) + .toggle__content:before {
  border-color: rgba(31, 32, 65, 0.25);
}

.toggle__box:checked + .toggle__content:after,
.toggle__box:not(:checked) + .toggle__content:after {
  content: "";
  position: absolute;
  transition: all 0.2s ease;
}

.toggle__box:checked + .toggle__content:after,
.toggle__box:not(:checked) + .toggle__content:after {
  position: absolute;
  left: 24px;
  top: 4px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: linear-gradient(#bc9cff, #8ba4f9);
}

.toggle__box:not(:checked) + .toggle__content:after {
  left: 4px;
  background: rgba(31, 32, 65, 0.25);
}

.toggle__box:checked + .toggle__content:after {
  opacity: 1;
}
