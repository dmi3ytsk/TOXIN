.textfield__form {
  margin-top: 5px;
  margin-bottom: 10px;
  height: 44px;
  position: relative;
  display: flex;
}
.textfield__input {
  width: 100%;
  color: rgba(31, 32, 65, 0.75);
  border: 1px solid rgba(31, 32, 65, 0.25);
  border-radius: 4px;
  padding: 12px 15px 12px 15px;
  display: flex;
  flex: 1;
  position: relative;
}
.textfield__input:hover, .textfield__input:focus {
  color: rgba(31, 32, 65, 0.75);
  border-color: rgba(31, 32, 65, 0.5);
}
.textfield__input::placeholder {
  color: rgba(31, 32, 65, 0.25);
}
.textfield__downArrow, .textfield__forwardArrow {
  color: rgba(31, 32, 65, 0.5);
  font-size: 24px;
  line-height: 24px;
  position: absolute;
  right: 9px;
  top: 25%;
  pointer-events: none;
}
.textfield__forwardArrow {
  pointer-events: auto;
  background: linear-gradient(#bc9cff, #8ba4f9);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: #bc9cff;
}
